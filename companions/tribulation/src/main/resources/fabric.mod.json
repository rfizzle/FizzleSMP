{
    "schemaVersion": 1,
    "id": "tribulation",
    "version": "${version}",
    "name": "Tribulation",
    "description": "Unified mob scaling system for FizzleSMP — replaces HMIOT and RpgDifficulty with formula-driven time, distance, and height scaling.",
    "authors": ["rfizzle"],
    "contact": {},
    "license": "MIT",
    "icon": "assets/tribulation/icon.png",
    "environment": "*",
    "entrypoints": {
        "main": ["com.rfizzle.tribulation.Tribulation"],
        "fabric-gametest": ["com.rfizzle.tribulation.gametest.MobScalingGameTest"],
        "modmenu": ["com.rfizzle.tribulation.compat.modmenu.ModMenuIntegration"],
        "jade": ["com.rfizzle.tribulation.compat.jade.JadeTribulationPlugin"],
        "emi": ["com.rfizzle.tribulation.compat.emi.EmiShardPlugin"],
        "rei_client": ["com.rfizzle.tribulation.compat.rei.ReiShardPlugin"],
        "jei_mod_plugin": ["com.rfizzle.tribulation.compat.jei.JeiShardPlugin"]
    },
    "suggests": {
        "modmenu": "*",
        "jade": "*",
        "wthit": "*",
        "emi": "*",
        "roughlyenoughitems": "*",
        "jei": "*"
    },
    "mixins": [
        "tribulation.mixins.json"
    ],
    "depends": {
        "fabricloader": ">=0.16.10",
        "minecraft": "~1.21.1",
        "java": ">=21",
        "fabric-api": "*"
    }
}
